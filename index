function statusTone(status: string) {
  if (status === "active") return "bg-emerald-400/15 text-emerald-200 border-emerald-400/20";
  if (status === "review") return "bg-amber-400/15 text-amber-200 border-amber-400/20";
  if (status === "watching") return "bg-sky-400/15 text-sky-200 border-sky-400/20";
  return "bg-white/10 text-white/80 border-white/10";
}

function eventIcon(kind: string) {
  switch (kind) {
    case "plan":
      return Wand2;
    case "tool":
      return Terminal;
    case "research":
      return Search;
    case "review":
      return CheckCircle2;
    case "ship":
      return Send;
    default:
      return Activity;
  }
}

function priorityTone(priority: string) {
  if (priority === "High") return "text-rose-200 border-rose-400/20 bg-rose-400/10";
  if (priority === "Medium") return "text-amber-200 border-amber-400/20 bg-amber-400/10";
  if (priority === "Done") return "text-emerald-200 border-emerald-400/20 bg-emerald-400/10";
  return "text-white/70 border-white/10 bg-white/5";
}

